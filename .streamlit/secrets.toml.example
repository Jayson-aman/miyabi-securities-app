# ═══════════════════════════════════════════════════════════════
#  Zaibase.Economic Research - Streamlit Secrets テンプレート
# ═══════════════════════════════════════════════════════════════
#
# ⚠ このファイルはテンプレートです。実際の値は絶対にコミットしないでください。
# ⚠ 本番用は .streamlit/secrets.toml（.gitignore対象）に保存してください。
#
# 【連絡があるまで非公開】
#   closed_until_notice = true のまま運用してください。
#   一般公開するときだけ false に変更し Reboot。
#
# 【Streamlit Cloud】
#   Settings → Secrets に貼り付け → Reboot app
# ═══════════════════════════════════════════════════════════════

[app]
# 連絡・確認が整うまで一般公開しない（true 推奨）
closed_until_notice = true
closed_message = "連絡・確認が整うまで一般公開しておりません。お問い合わせ: info@zaibase.group"
# 一時公開（非公開中は必ず false）
preview_public = false

[auth]
enabled = true
session_hours = 24
salt = "ここに64文字のhex文字列が入る（generate_password_hash.py で生成）"
hash = "ここに64文字のhex文字列が入る（generate_password_hash.py で生成）"

[legal]
operator_name = "南條 雅哉（Zaibase.Economic Research）"
contact_email = "info@zaibase.group"
# 所在地 — Streamlit Cloud Secrets にのみ記載（Git にコミットしない）
# address = "大阪市天王寺区..."
# 一般公開時のみ true にすると特商法表記に住所を表示
show_address = false

[email_alert]
# 非公開中は false 推奨
enabled = false
to_addr = "info@zaibase.group"
smtp_host = "smtp.gmail.com"
smtp_port = 587
smtp_user = "送信用メールアドレス"
smtp_password = "アプリパスワード"
from_addr = "送信用メールアドレス"
threshold_yen = 0.3
cooldown_minutes = 60

[billing]
# 非公開中は false 推奨
enabled = false
pro_price_display = "¥1,980 / 月（研究・検討用）"
stripe_payment_link = "https://buy.stripe.com/xxxxxxxx"
pro_license_keys = ["ZAIBASE-PRO-DEMO-2026"]
