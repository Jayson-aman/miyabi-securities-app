# ═══════════════════════════════════════════════════════════════
#  雅証券 MIYABI Securities - Streamlit Secrets テンプレート
# ═══════════════════════════════════════════════════════════════
#
# ⚠ このファイルはテンプレートです。実際の値は絶対にコミットしないでください。
# ⚠ 本番用は .streamlit/secrets.toml（.gitignore対象）に保存してください。
#
# 【ローカル検証】
#   このファイルを secrets.toml にコピーし、値を書き換えてください。
#
# 【Streamlit Cloud】
#   generate_password_hash.py で生成した値を
#   Cloud ダッシュボードの Settings → Secrets に貼り付けてください。
# ═══════════════════════════════════════════════════════════════

[auth]
# python3 generate_password_hash.py で生成した値を貼り付け
salt = "ここに64文字のhex文字列が入る（generate_password_hash.py で生成）"
hash = "ここに64文字のhex文字列が入る（generate_password_hash.py で生成）"
